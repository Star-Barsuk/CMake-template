{
    "version": 8,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 28,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "debug",
            "inherits": "base",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ENABLE_IPO": "OFF"
            }
        },
        {
            "name": "release",
            "inherits": "base",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "ENABLE_IPO": "OFF"
            }
        },
        {
            "name": "single",
            "inherits": "debug",
            "binaryDir": "${sourceDir}/build/single",
            "cacheVariables": {
                "SINGLE_APP": "ON"
            }
        },
        {
            "name": "debug-sanitize",
            "inherits": "debug",
            "cacheVariables": {
                "ENABLE_SANITIZERS": "ON"
            }
        },
        {
            "name": "release-lto",
            "inherits": "release",
            "cacheVariables": {
                "ENABLE_IPO": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "configurePreset": "release"
        },
        {
            "name": "single",
            "configurePreset": "single"
        },
        {
            "name": "debug-sanitize",
            "configurePreset": "debug-sanitize"
        },
        {
            "name": "release-lto",
            "configurePreset": "release-lto"
        }
    ]
}
